<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sms.system.mapper.notification.NotificationAnswerMapper">

    <resultMap type="com.sms.system.entity.notification.NotificationAnswer" id="NotificationAnswerResult">
        <result property="answerId"    column="answer_id"    />
        <result property="notificationId"    column="notification_id"    />
        <result property="questionId"    column="question_id"    />
        <result property="userId"    column="user_id"    />
        <result property="userType"    column="user_type"    />
        <result property="answerData"    column="answer_data"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <select id="selectByNotificationId" resultMap="NotificationAnswerResult">
        select answer_id, notification_id, question_id, user_id, user_type,
               answer_data, create_time
        from notification_answer
        where notification_id = #{notificationId}
        order by create_time asc
    </select>

    <select id="selectByNotificationIdAndUserId" resultMap="NotificationAnswerResult">
        select answer_id, notification_id, question_id, user_id, user_type,
               answer_data, create_time
        from notification_answer
        where notification_id = #{notificationId}
          and user_id = #{userId}
        order by create_time asc
    </select>

</mapper>
