<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sms.system.mapper.SysSchoolDepartmentMemberMapper">

    <resultMap type="com.sms.system.entity.SysSchoolDepartmentMember" id="SysSchoolDepartmentMemberResult">
        <result property="id" column="id"/>
        <result property="userid" column="userid"/>
        <result property="name" column="name"/>
        <result property="departmentId" column="department_id"/>
        <result property="openUserid" column="open_userid"/>
        <result property="type" column="type"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 批量查詢多個部門的成員 -->
    <select id="selectMembersByDepartmentIds" resultMap="SysSchoolDepartmentMemberResult">
        SELECT id, userid, name, department_id, open_userid, type, create_time, update_time
        FROM sys_school_department_member
        WHERE department_id IN
        <foreach collection="departmentIds" item="departmentId" open="(" separator="," close=")">
            #{departmentId}
        </foreach>
        ORDER BY department_id ASC, name ASC
    </select>

    <!-- 根據 ID 刪除部門成員 -->
    <delete id="deleteMemberById" parameterType="Long">
        DELETE FROM sys_school_department_member
        WHERE id = #{id}
    </delete>

    <!-- 根據部門 ID 刪除成員 -->
    <delete id="deleteByDepartmentId" parameterType="Long">
        DELETE FROM sys_school_department_member
        WHERE department_id = #{departmentId}
    </delete>

    <!-- 批量插入部門成員 -->
    <insert id="batchInsertMembers">
        INSERT INTO sys_school_department_member (userid, name, department_id, open_userid, type, create_time, update_time)
        VALUES
        <foreach collection="members" item="member" separator=",">
            (
                #{member.userid},
                #{member.name},
                #{member.departmentId},
                #{member.openUserid},
                #{member.type},
                now(),
                now()
            )
        </foreach>
    </insert>

</mapper>
