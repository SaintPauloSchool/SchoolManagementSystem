<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sms.system.mapper.SysParentStudentRelationMapper">
    
    <resultMap type="com.sms.system.entity.SysParentStudentRelation" id="SysParentStudentRelationResult">
        <result property="id" column="id"/>
        <result property="parentUserId" column="parent_user_id"/>
        <result property="studentUserId" column="student_user_id"/>
        <result property="studentName" column="student_name"/>
        <result property="relationDesc" column="relation_desc"/>
        <result property="mobile" column="mobile"/>
        <result property="externalUserid" column="external_userid"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 批量查詢家長學生關係 -->
    <select id="selectByParentUserIds" resultMap="SysParentStudentRelationResult">
        SELECT id, parent_user_id, student_user_id, student_name, relation_desc, mobile, external_userid, create_time, update_time
        FROM sys_parent_student_relation
        WHERE parent_user_id IN
        <foreach collection="parentUserIds" item="parentUserId" open="(" separator="," close=")">
            #{parentUserId}
        </foreach>
    </select>

</mapper>
