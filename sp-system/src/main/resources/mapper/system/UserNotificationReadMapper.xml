<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sp.system.mapper.notification.UserNotificationReadMapper">

    <resultMap type="com.sp.system.entity.notification.UserNotificationRead" id="UserNotificationReadResult">
        <result property="readId" column="read_id"/>
        <result property="notificationId" column="notification_id"/>
        <result property="userId" column="user_id"/>
        <result property="userType" column="user_type"/>
        <result property="isRead" column="is_read"/>
        <result property="readTime" column="read_time"/>
        <result property="replyStatus" column="reply_status"/>
        <result property="replyTime" column="reply_time"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectUserNotificationReadVo">
        select read_id, notification_id, user_id, user_type, is_read, 
               read_time, reply_status, reply_time, create_time
        from user_notification_read
    </sql>

    <select id="selectByNotificationId" parameterType="Long" resultMap="UserNotificationReadResult">
        <include refid="selectUserNotificationReadVo"/>
        where notification_id = #{notificationId}
        order by create_time asc
    </select>

    <select id="selectByUserId" resultMap="UserNotificationReadResult">
        <include refid="selectUserNotificationReadVo"/>
        where user_id = #{userId} and user_type = #{userType}
        order by create_time desc
    </select>

</mapper>