<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sp.system.mapper.notification.NotificationQuestionMapper">

    <resultMap type="com.sp.system.entity.notification.NotificationQuestion" id="NotificationQuestionResult">
        <result property="questionId" column="question_id"/>
        <result property="notificationId" column="notification_id"/>
        <result property="parentQuestionId" column="parent_question_id"/>
        <result property="questionTitle" column="question_title"/>
        <result property="questionType" column="question_type"/>
        <result property="options" column="options"/>
        <result property="isRequired" column="is_required"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectNotificationQuestionVo">
        select question_id, notification_id, parent_question_id, question_title, 
               question_type, options, is_required, sort_order, create_time
        from notification_question
    </sql>

    <select id="selectByNotificationId" parameterType="Long" resultMap="NotificationQuestionResult">
        <include refid="selectNotificationQuestionVo"/>
        where notification_id = #{notificationId}
        order by sort_order asc, create_time asc
    </select>

    <select id="selectByParentQuestionId" parameterType="Long" resultMap="NotificationQuestionResult">
        <include refid="selectNotificationQuestionVo"/>
        where parent_question_id = #{parentQuestionId}
        order by sort_order asc, create_time asc
    </select>

</mapper>