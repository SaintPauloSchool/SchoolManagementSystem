<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sp.system.mapper.SysSchoolDepartmentMapper">

    <resultMap type="com.sp.system.entity.SysSchoolDepartment" id="SysSchoolDepartmentResult">
        <result property="id" column="id"/>
        <result property="parentId" column="parent_id"/>
        <result property="name" column="name"/>
        <result property="nameEn" column="name_en"/>
        <result property="orderNum" column="order_num"/>
        <result property="departmentLeader" column="department_leader"/>
        <result property="type" column="type"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 查詢所有部門 -->
    <select id="selectAll" resultMap="SysSchoolDepartmentResult">
        SELECT id, parent_id, name, name_en, order_num, 
               department_leader, type, create_time, update_time
        FROM sys_school_department
        <where>
            <if test="type != null">
                AND type = #{type}
            </if>
        </where>
        ORDER BY order_num ASC
    </select>

    <!-- 根據 ID 刪除學校部門 -->
    <delete id="deleteById" parameterType="Long">
        DELETE FROM sys_school_department
        WHERE id = #{id}
    </delete>

    <!-- 根據 ID 批量刪除學校部門 -->
    <delete id="deleteByIds">
        DELETE FROM sys_school_department
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 插入部门信息 -->
    <insert id="insertDepartment" parameterType="com.sp.system.entity.SysSchoolDepartment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_school_department (
            <if test="parentId != null">parent_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="nameEn != null and nameEn != ''">name_en,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="departmentLeader != null and departmentLeader != ''">department_leader,</if>
            <if test="type != null">type,</if>
            create_time,
            update_time
        ) VALUES (
            <if test="parentId != null">#{parentId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="nameEn != null and nameEn != ''">#{nameEn},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="departmentLeader != null and departmentLeader != ''">#{departmentLeader},</if>
            <if test="type != null">#{type},</if>
            now(),
            now()
        )
    </insert>

    <!-- 修改部門信息 -->
    <update id="updateDepartment" parameterType="com.sp.system.entity.SysSchoolDepartment">
        UPDATE sys_school_department
        <set>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="nameEn != null and nameEn != ''">name_en = #{nameEn},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="departmentLeader != null and departmentLeader != ''">department_leader = #{departmentLeader},</if>
            <if test="type != null">type = #{type},</if>
            update_time = now(),
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根據 ID 查詢部門 -->
    <select id="selectById" parameterType="Long" resultMap="SysSchoolDepartmentResult">
        SELECT id, parent_id, name, name_en, order_num, 
               department_leader, type, create_time, update_time
        FROM sys_school_department
        WHERE id = #{id}
    </select>

</mapper>
