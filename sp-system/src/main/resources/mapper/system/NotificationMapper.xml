<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sp.system.mapper.notification.NotificationMapper">

    <resultMap type="com.sp.system.entity.notification.Notification" id="NotificationResult">
        <result property="notificationId" column="notification_id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="senderId" column="sender_id"/>
        <result property="senderName" column="sender_name"/>
        <result property="jumpUrl" column="jump_url"/>
        <result property="attachmentUrls" column="attachment_urls"/>
        <result property="status" column="status"/>
        <result property="replyDeadline" column="reply_deadline"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectNotificationVo">
        select notification_id, title, content, sender_id, sender_name, jump_url, 
               attachment_urls, status, reply_deadline, create_by, create_time, 
               update_by, update_time, remark
        from notification
    </sql>

    <select id="selectNotificationList" parameterType="com.sp.system.entity.notification.Notification" resultMap="NotificationResult">
        <include refid="selectNotificationVo"/>
        <where>
            <if test="title != null and title != ''">
                AND title like concat('%', #{title}, '%')
            </if>
            <if test="senderName != null and senderName != ''">
                AND sender_name like concat('%', #{senderName}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="selectCcToMeList" resultMap="NotificationResult">
        SELECT DISTINCT n.*
        FROM notification n
        INNER JOIN notification_cc cc ON n.notification_id = cc.notification_id
        WHERE (
            (cc.cc_type = '1' AND cc.cc_ids LIKE CONCAT('%,', #{userId}, ',%'))
            OR 
            (cc.cc_type = '2' AND cc.cc_ids LIKE CONCAT('%,', #{userId}, ',%'))
        )
        AND n.status = '1'
        ORDER BY n.create_time DESC
    </select>

    <select id="selectMySendList" resultMap="NotificationResult">
        <include refid="selectNotificationVo"/>
        WHERE sender_id = #{senderId}
        ORDER BY create_time DESC
    </select>

</mapper>